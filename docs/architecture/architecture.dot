digraph architecture {
    // GENERATED by scripts/gen-arch-diagram.sh -- do not edit by hand.
    graph [
        label="git-branch-manager — layered architecture",
        labelloc=t, fontname=Helvetica, fontsize=28,
        layout=dot, rankdir=TB, newrank=true,
        splines=polyline, concentrate=true,
        ranksep=1.1, nodesep=0.3, pad=0.4,
    ];
    node [shape=box, style="rounded,filled", fontname=monospace,
          fontsize=11, margin="0.12,0.06"];
    edge [fontname=monospace, fontsize=9];

    subgraph cluster_L6 {
        label="L6 · Entrypoint (binary)"; style=filled; color="#aaaaaa";
        fillcolor="#f2f2f2"; fontname=Helvetica; fontsize=14;
        node [fillcolor="#c8c8c8"];
        "main" [label="main"];
    }

    subgraph cluster_L5 {
        label="L5 · App state machine (binary)"; style=filled; color="#aaaaaa";
        fillcolor="#fffae6"; fontname=Helvetica; fontsize=14;
        node [fillcolor="#ffe066"];
        "app" [label="app"];
    }

    subgraph cluster_L4 {
        label="L4 · UI widgets"; style=filled; color="#aaaaaa";
        fillcolor="#ffeeee"; fontname=Helvetica; fontsize=14;
        node [fillcolor="#ff9f9f"];
        "git_branch_manager::ui" [label="ui"];
        "git_branch_manager::ui::confirm" [label="ui::confirm"];
        "git_branch_manager::ui::executing" [label="ui::executing"];
