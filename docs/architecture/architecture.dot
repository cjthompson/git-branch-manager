    // force one horizontal band per layer
    { rank=same; "git_branch_manager::ui"; "git_branch_manager::ui::confirm"; "git_branch_manager::ui::executing"; "git_branch_manager::ui::filter_ui"; "git_branch_manager::ui::help"; "git_branch_manager::ui::list_render"; "git_branch_manager::ui::menu"; "git_branch_manager::ui::render"; "git_branch_manager::ui::results"; "git_branch_manager::ui::settings"; "git_branch_manager::ui::shared"; "git_branch_manager::ui::status_bar"; "git_branch_manager::ui::tab_bar"; "git_branch_manager::ui::toast"; }
